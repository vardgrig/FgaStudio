<!DOCTYPE html>
<html lang="en" data-bs-theme="dark" id="html-root">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FGA Studio</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <script>
        (function () {
            var theme = localStorage.getItem('fga-theme') || 'dark';
            document.getElementById('html-root').setAttribute('data-bs-theme', theme);
        })();
    </script>
</head>
<body>

<!-- Mobile top bar -->
<header class="mobile-topbar d-flex d-lg-none align-items-center gap-3 px-3">
    <button class="btn btn-link p-0 text-body" type="button"
            data-bs-toggle="offcanvas" data-bs-target="#sidebar-offcanvas" aria-label="Open menu">
        <i class="bi bi-list fs-4"></i>
    </button>
    <span class="brand-name">FGA Studio</span>
</header>

<div class="d-flex" style="min-height:100vh">

    <!-- Sidebar — offcanvas on mobile, sticky panel on desktop -->
    <nav class="sidebar offcanvas-lg offcanvas-start d-flex flex-column flex-shrink-0 p-3"
         id="sidebar-offcanvas" tabindex="-1">

        <div class="offcanvas-header d-lg-none px-0 pb-3">
            <span class="brand-name">FGA Studio</span>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#sidebar-offcanvas"></button>
        </div>

        <a href="/" class="sidebar-brand d-none d-lg-flex align-items-center gap-2 mb-4 text-decoration-none">
            <span class="brand-icon"><i class="bi bi-diagram-3-fill"></i></span>
            <span class="brand-name">FGA Studio</span>
        </a>

        <div class="sidebar-section-label">Navigation</div>
        <ul class="nav nav-pills flex-column mb-3 gap-1">
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")" href="/">
                    <i class="bi bi-grid-1x2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Stores" ? "active" : "")" href="/Stores">
                    <i class="bi bi-database"></i> Stores
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Tuples" ? "active" : "")" href="/Tuples">
                    <i class="bi bi-table"></i> Tuples
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "TupleTree" ? "active" : "")" href="/TupleTree">
                    <i class="bi bi-diagram-2"></i> Tuple Tree
                </a>
            </li>
        </ul>

        <div class="sidebar-section-label">Config</div>
        <ul class="nav nav-pills flex-column gap-1">
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Connections" ? "active" : "")" href="/Connection">
                    <i class="bi bi-plug"></i> Connections
                </a>
            </li>
        </ul>

        <!-- Active connection badge -->
        <div class="mt-auto pt-3 border-top border-secondary">
            @if (ViewData["ActiveConnection"] is string activeConn && !string.IsNullOrEmpty(activeConn))
            {
                <div class="d-flex align-items-center gap-2">
                    <span class="status-dot status-dot--online"></span>
                    <span class="small text-truncate" title="@activeConn">@activeConn</span>
                </div>
                @if (ViewData["ActiveStore"] is string storeId && !string.IsNullOrEmpty(storeId))
                {
                    <div class="small text-secondary mt-1 text-truncate" title="@storeId">
                        <i class="bi bi-database me-1"></i>@storeId[..Math.Min(12, storeId.Length)]…
                    </div>
                }
            }
            else
            {
                <div class="d-flex align-items-center gap-2">
                    <span class="status-dot status-dot--offline"></span>
                    <span class="small text-secondary">No connection</span>
                </div>
            }

            <button class="theme-toggle mt-3" id="theme-toggle" onclick="toggleTheme()">
                <i class="bi" id="theme-icon"></i>
                <span id="theme-label"></span>
            </button>
        </div>
    </nav>

    <!-- Main content -->
    <div class="main-content flex-grow-1 d-flex flex-column">
        <main class="flex-grow-1 p-3 p-md-4">
            @if (TempData["Success"] is string success)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@success
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] is string error)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@error
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function applyTheme(theme) {
        document.getElementById('html-root').setAttribute('data-bs-theme', theme);
        var icon = document.getElementById('theme-icon');
        var label = document.getElementById('theme-label');
        if (theme === 'dark') {
            icon.className = 'bi bi-sun';
            label.textContent = 'Light mode';
        } else {
            icon.className = 'bi bi-moon';
            label.textContent = 'Dark mode';
        }
    }

    function toggleTheme() {
        var current = document.getElementById('html-root').getAttribute('data-bs-theme');
        var next = current === 'dark' ? 'light' : 'dark';
        localStorage.setItem('fga-theme', next);
        applyTheme(next);
    }

    applyTheme(localStorage.getItem('fga-theme') || 'dark');
</script>
</body>
</html>
