@page
@model FgaStudio.Web.Pages.Connection.IndexModel
@{
    ViewData["Title"] = "Connections";
    ViewData["ActivePage"] = "Connections";
    ViewData["ActiveConnection"] = Model.ActiveConnectionName;
    ViewData["ActiveStore"] = Model.ActiveStoreId;
}

<div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-4">
    <div>
        <h1 class="page-title mb-1">Connections</h1>
        <p class="text-secondary mb-0">Manage your OpenFGA server and database connections.</p>
    </div>
    <a href="/Connection/Configure" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Connection
    </a>
</div>

@if (!Model.Connections.Any())
{
    <div class="empty-state card text-center p-5">
        <i class="bi bi-plug display-4 text-secondary mb-3 d-block"></i>
        <h5>No connections configured</h5>
        <p class="text-secondary">Add your first connection to an OpenFGA server or PostgreSQL database.</p>
        <a href="/Connection/Configure" class="btn btn-primary mt-2">
            <i class="bi bi-plus-lg me-1"></i> Add Connection
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var conn in Model.Connections)
        {
            var isActive = conn.Name == Model.ActiveConnectionName;
            <div class="col-12">
                <div class="card connection-card @(isActive ? "connection-card--active" : "")">
                    <div class="card-body d-flex align-items-start gap-3 flex-wrap">
                        <div class="connection-icon">
                            <i class="bi @(conn.Type == ConnectionType.Url ? "bi-globe2" : "bi-server")"></i>
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="fw-semibold">@conn.Name</span>
                                @if (isActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                <span class="badge @(conn.Type == ConnectionType.Url ? "badge--url" : "badge--db")">
                                    @conn.Type
                                </span>
                            </div>
                            <div class="small text-secondary font-mono text-truncate">
                                @(conn.Type == ConnectionType.Url ? conn.ApiUrl : conn.ConnectionString)
                            </div>
                            @if (!string.IsNullOrEmpty(conn.StoreId))
                            {
                                <div class="small text-secondary mt-1">
                                    <i class="bi bi-database me-1"></i>Store: <span class="font-mono">@conn.StoreId</span>
                                </div>
                            }
                        </div>
                        <div class="d-flex gap-2 flex-shrink-0">
                            @if (!isActive)
                            {
                                <form method="post" asp-page-handler="SetActive">
                                    <input type="hidden" name="name" value="@conn.Name" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-check2-circle me-1"></i>Set Active
                                    </button>
                                </form>
                            }
                            <a href="/Connection/Configure?name=@Uri.EscapeDataString(conn.Name)" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" asp-page-handler="Delete"
                                  onsubmit="return confirm('Delete connection \'@conn.Name\'?')">
                                <input type="hidden" name="name" value="@conn.Name" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
