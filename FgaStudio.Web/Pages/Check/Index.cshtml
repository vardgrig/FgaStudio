@page
@model FgaStudio.Web.Pages.Check.IndexModel
@{
    ViewData["Title"] = "Check";
    ViewData["ActivePage"] = "Check";
    ViewData["ActiveConnection"] = Model.ActiveConnectionName;
    ViewData["ActiveStore"] = Model.ActiveStoreId;

    var mode = Model.Mode;
}

<div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-4">
    <div>
        <h1 class="page-title mb-1">Relationship Queries</h1>
        <p class="text-secondary mb-0">Run Check, Expand, List Objects, or List Users against the active store.</p>
    </div>
    @if (!string.IsNullOrEmpty(Model.ActiveConnectionName))
    {
        <span class="badge bg-body-secondary text-body border">
            <i class="bi bi-plug me-1"></i>@Model.ActiveConnectionName
        </span>
    }
</div>

@if (!Model.IsReady)
{
    <div class="empty-state card text-center p-5">
        @if (Model.ActiveConnection is null)
        {
            <i class="bi bi-plug display-4 text-secondary mb-3 d-block"></i>
            <h5>No active connection</h5>
            <p class="text-secondary">Set an active connection to run relationship queries.</p>
            <a href="/Connection" class="btn btn-primary">Go to Connections</a>
        }
        else
        {
            <i class="bi bi-database display-4 text-secondary mb-3 d-block"></i>
            <h5>No store selected</h5>
            <p class="text-secondary">Select a store before running queries.</p>
            <a href="/Stores" class="btn btn-primary">Go to Stores</a>
        }
    </div>
}
else
{
    @if (Model.IsDbMode)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
            <span>Relationship queries (Check, Expand, List Objects, List Users) require the OpenFGA evaluation engine and are only available in <strong>HTTP API</strong> mode.</span>
        </div>
    }

    <!-- Mode tabs -->
    <ul class="nav nav-tabs mb-4" id="query-tabs">
        @foreach (var (tabMode, label, icon) in new (string, string, string)[]
        {
            ("check",        "Check",        "bi-shield-check"),
            ("expand",       "Expand",       "bi-diagram-3"),
            ("list-objects", "List Objects", "bi-box"),
            ("list-users",   "List Users",   "bi-people"),
        })
        {
            var isActive = mode == tabMode;
            <li class="nav-item">
                <a class="nav-link @(isActive ? "active" : "")"
                   href="/Check?mode=@tabMode">
                    <i class="bi @icon me-1"></i>@label
                </a>
            </li>
        }
    </ul>

    <div class="row g-4">
        <!-- ── Left: form ─────────────────────────────────────────── -->
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body p-4">

                    @if (mode == "check")
                    {
                        <h6 class="fw-semibold mb-1">Check</h6>
                        <p class="small text-secondary mb-3">Does <em>user</em> have <em>relation</em> on <em>object</em>?</p>
                        <form method="get">
                            <input type="hidden" name="mode" value="check" />
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">User</label>
                                <input name="User" value="@Model.User" class="form-control form-control-sm font-mono"
                                       placeholder="user:alice" autofocus />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Relation</label>
                                <input name="Relation" value="@Model.Relation" class="form-control form-control-sm font-mono"
                                       placeholder="viewer" />
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-semibold small">Object</label>
                                <input name="Object" value="@Model.Object" class="form-control form-control-sm font-mono"
                                       placeholder="document:readme" />
                            </div>
                            <button type="submit" class="btn btn-primary w-100" @(Model.IsDbMode ? "disabled" : "")>
                                <i class="bi bi-shield-check me-1"></i>Check
                            </button>
                        </form>
                    }
                    else if (mode == "expand")
                    {
                        <h6 class="fw-semibold mb-1">Expand</h6>
                        <p class="small text-secondary mb-3">Who has <em>relation</em> on <em>object</em>? Returns the full userset tree.</p>
                        <form method="get">
                            <input type="hidden" name="mode" value="expand" />
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Relation</label>
                                <input name="Relation" value="@Model.Relation" class="form-control form-control-sm font-mono"
                                       placeholder="viewer" autofocus />
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-semibold small">Object</label>
                                <input name="Object" value="@Model.Object" class="form-control form-control-sm font-mono"
                                       placeholder="document:readme" />
                            </div>
                            <button type="submit" class="btn btn-primary w-100" @(Model.IsDbMode ? "disabled" : "")>
                                <i class="bi bi-diagram-3 me-1"></i>Expand
                            </button>
                        </form>
                    }
                    else if (mode == "list-objects")
                    {
                        <h6 class="fw-semibold mb-1">List Objects</h6>
                        <p class="small text-secondary mb-3">What objects of <em>type</em> does <em>user</em> have <em>relation</em> on?</p>
                        <form method="get">
                            <input type="hidden" name="mode" value="list-objects" />
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">User</label>
                                <input name="User" value="@Model.User" class="form-control form-control-sm font-mono"
                                       placeholder="user:alice" autofocus />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Relation</label>
                                <input name="Relation" value="@Model.Relation" class="form-control form-control-sm font-mono"
                                       placeholder="viewer" />
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-semibold small">Object Type</label>
                                <input name="Type" value="@Model.Type" class="form-control form-control-sm font-mono"
                                       placeholder="document" />
                            </div>
                            <button type="submit" class="btn btn-primary w-100" @(Model.IsDbMode ? "disabled" : "")>
                                <i class="bi bi-box me-1"></i>List Objects
                            </button>
                        </form>
                    }
                    else if (mode == "list-users")
                    {
                        <h6 class="fw-semibold mb-1">List Users</h6>
                        <p class="small text-secondary mb-3">Who has <em>relation</em> on <em>object</em>?</p>
                        <form method="get">
                            <input type="hidden" name="mode" value="list-users" />
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Object</label>
                                <input name="Object" value="@Model.Object" class="form-control form-control-sm font-mono"
                                       placeholder="document:readme" autofocus />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Relation</label>
                                <input name="Relation" value="@Model.Relation" class="form-control form-control-sm font-mono"
                                       placeholder="viewer" />
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-semibold small">User Type Filter</label>
                                <input name="UserType" value="@Model.UserType" class="form-control form-control-sm font-mono"
                                       placeholder="user" />
                                <div class="form-text">Object type to filter returned users by (e.g. <code>user</code>, <code>group</code>).</div>
                            </div>
                            <button type="submit" class="btn btn-primary w-100" @(Model.IsDbMode ? "disabled" : "")>
                                <i class="bi bi-people me-1"></i>List Users
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

        <!-- ── Right: result ──────────────────────────────────────── -->
        <div class="col-lg-7">
            @if (!Model.HasResult)
            {
                <div class="card h-100 d-flex align-items-center justify-content-center text-center p-5" style="min-height:200px">
                    <i class="bi bi-arrow-left-circle display-4 text-secondary mb-3 d-block"></i>
                    <p class="text-secondary mb-0">Fill in the form and submit to see results.</p>
                </div>
            }
            else if (Model.Error is not null)
            {
                <div class="alert alert-danger d-flex align-items-start gap-2">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
                    <span class="font-mono small">@Model.Error</span>
                </div>
            }
            else if (mode == "check")
            {
                <div class="card text-center p-5">
                    @if (Model.Allowed == true)
                    {
                        <div class="check-result check-result--allowed mb-3">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <h4 class="fw-bold text-success mb-1">ALLOWED</h4>
                    }
                    else
                    {
                        <div class="check-result check-result--denied mb-3">
                            <i class="bi bi-shield-x"></i>
                        </div>
                        <h4 class="fw-bold text-danger mb-1">DENIED</h4>
                    }
                    <div class="font-mono small text-secondary mt-2">
                        <span class="text-info">@Model.User</span>
                        <span class="mx-2 text-secondary">→</span>
                        <span class="relation-badge">@Model.Relation</span>
                        <span class="mx-2 text-secondary">→</span>
                        <span class="text-success">@Model.Object</span>
                    </div>
                </div>
            }
            else if (mode == "expand")
            {
                if (Model.TreeJson is null)
                {
                    <div class="card p-4 text-center text-secondary">No tree returned.</div>
                }
                else
                {
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <h6 class="fw-semibold mb-0 me-auto">
                            <i class="bi bi-diagram-3 me-1 text-secondary"></i>Userset Tree
                        </h6>
                        <button class="btn btn-sm btn-outline-secondary" onclick="jvExpandAll()"><i class="bi bi-arrows-expand"></i></button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="jvCollapseAll()"><i class="bi bi-arrows-collapse"></i></button>
                        <button class="btn btn-sm btn-outline-secondary" id="copy-tree-btn" onclick="copyTree()">
                            <i class="bi bi-clipboard me-1"></i>Copy
                        </button>
                    </div>
                    <pre id="tree-raw" style="display:none">@Model.TreeJson</pre>
                    <div class="jv-container" id="jv-root">
                        <div class="jv-loading text-secondary small p-3"><i class="bi bi-hourglass-split me-1"></i>Rendering…</div>
                    </div>
                }
            }
            else
            {
                <!-- list-objects / list-users -->
                var label = mode == "list-objects" ? "Objects" : "Users";
                <div class="card">
                    <div class="card-header d-flex align-items-center gap-2 py-2 px-3">
                        <i class="bi @(mode == "list-objects" ? "bi-box" : "bi-people") text-secondary"></i>
                        <span class="fw-semibold small">@label</span>
                        <span class="badge bg-body-secondary text-body border ms-auto">@Model.ResultList.Count</span>
                    </div>
                    @if (!Model.ResultList.Any())
                    {
                        <div class="p-4 text-center text-secondary small">No @label.ToLower() found.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.ResultList)
                            {
                                <li class="list-group-item d-flex align-items-center gap-2 py-2 px-3">
                                    <i class="bi @(mode == "list-objects" ? "bi-box" : "bi-person") text-secondary small"></i>
                                    <span class="font-mono small">@item</span>
                                    @if (mode == "list-objects")
                                    {
                                        <a href="/TupleTree?object=@Uri.EscapeDataString(item)"
                                           class="btn btn-sm btn-link p-0 ms-auto text-secondary small"
                                           title="View in Tuple Tree">
                                            <i class="bi bi-diagram-2"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="/TupleTree?user=@Uri.EscapeDataString(item)"
                                           class="btn btn-sm btn-link p-0 ms-auto text-secondary small"
                                           title="View in Tuple Tree">
                                            <i class="bi bi-diagram-2"></i>
                                        </a>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>
            }
        </div>
    </div>
}

<script>
// ─── JSON Viewer (reused from AuthModels/Details) ─────────────────────────────
var _jvSeq = 0;
function _jvId() { return 'jv' + (_jvSeq++); }
function _esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function _renderVal(v) {
    if (v === null)  return '<span class="jv-null">null</span>';
    if (v === true || v === false) return '<span class="jv-bool">'+v+'</span>';
    if (typeof v === 'number') return '<span class="jv-num">'+v+'</span>';
    if (typeof v === 'string') return '<span class="jv-str">&quot;'+_esc(v)+'&quot;</span>';
    if (Array.isArray(v)) return _renderArr(v);
    if (typeof v === 'object') return _renderObj(v);
    return _esc(String(v));
}
function _renderObj(obj) {
    var keys = Object.keys(obj);
    if (keys.length === 0) return '<span class="jv-brace">{}</span>';
    var id = _jvId(), preview = keys.length+' key'+(keys.length!==1?'s':'');
    var rows = keys.map(function(k,i){ var comma=i<keys.length-1?'<span class="jv-punct">,</span>':''; return '<div class="jv-row"><span class="jv-key">&quot;'+_esc(k)+'&quot;</span><span class="jv-colon">: </span>'+_renderVal(obj[k])+comma+'</div>'; }).join('');
    return '<span class="jv-brace">{</span><button class="jv-btn" data-jvid="'+id+'" onclick="jvToggle(this)" title="Collapse"><i class="bi bi-dash-square-dotted"></i></button><span class="jv-peek" id="pk-'+id+'" style="display:none"><span class="jv-brace">{ </span><span class="jv-dim">'+preview+'</span><span class="jv-brace"> }</span></span><div class="jv-block" id="'+id+'">'+rows+'</div><span class="jv-brace jv-close-brace">}</span>';
}
function _renderArr(arr) {
    if (arr.length === 0) return '<span class="jv-brace">[]</span>';
    var id = _jvId(), preview = arr.length+' item'+(arr.length!==1?'s':'');
    var rows = arr.map(function(v,i){ var comma=i<arr.length-1?'<span class="jv-punct">,</span>':''; return '<div class="jv-row">'+_renderVal(v)+comma+'</div>'; }).join('');
    return '<span class="jv-brace">[</span><button class="jv-btn" data-jvid="'+id+'" onclick="jvToggle(this)" title="Collapse"><i class="bi bi-dash-square-dotted"></i></button><span class="jv-peek" id="pk-'+id+'" style="display:none"><span class="jv-brace">[ </span><span class="jv-dim">'+preview+'</span><span class="jv-brace"> ]</span></span><div class="jv-block" id="'+id+'">'+rows+'</div><span class="jv-brace jv-close-brace">]</span>';
}
function jvToggle(btn) {
    var id=btn.dataset.jvid, block=document.getElementById(id), peek=document.getElementById('pk-'+id), icon=btn.querySelector('i'), open=block.style.display!=='none', sib=btn.parentElement.querySelector('.jv-close-brace');
    block.style.display=open?'none':''; peek.style.display=open?'inline':'none'; if(sib) sib.style.display=open?'none':'';
    icon.className=open?'bi bi-plus-square-dotted':'bi bi-dash-square-dotted'; btn.title=open?'Expand':'Collapse';
}
function jvExpandAll() { document.querySelectorAll('#jv-root .jv-btn').forEach(function(btn){ var id=btn.dataset.jvid, block=document.getElementById(id), peek=document.getElementById('pk-'+id), sib=btn.parentElement.querySelector('.jv-close-brace'); block.style.display=''; peek.style.display='none'; if(sib) sib.style.display=''; btn.querySelector('i').className='bi bi-dash-square-dotted'; btn.title='Collapse'; }); }
function jvCollapseAll() { document.querySelectorAll('#jv-root > .jv-wrap .jv-block > .jv-row .jv-btn').forEach(function(btn){ var id=btn.dataset.jvid, block=document.getElementById(id); if(!block) return; var peek=document.getElementById('pk-'+id), sib=btn.parentElement.querySelector('.jv-close-brace'); block.style.display='none'; peek.style.display='inline'; if(sib) sib.style.display='none'; btn.querySelector('i').className='bi bi-plus-square-dotted'; btn.title='Expand'; }); }
function copyTree() {
    var raw = document.getElementById('tree-raw'); if(!raw) return;
    navigator.clipboard.writeText(raw.textContent.trim()).then(function(){ var btn=document.getElementById('copy-tree-btn'), orig=btn.innerHTML; btn.innerHTML='<i class="bi bi-check me-1"></i>Copied'; btn.classList.replace('btn-outline-secondary','btn-outline-success'); setTimeout(function(){ btn.innerHTML=orig; btn.classList.replace('btn-outline-success','btn-outline-secondary'); },2000); });
}
(function(){
    var raw=document.getElementById('tree-raw'), root=document.getElementById('jv-root');
    if(!raw||!root) return;
    try { var parsed=JSON.parse(raw.textContent), wrap=document.createElement('div'); wrap.className='jv-wrap'; wrap.innerHTML=_renderVal(parsed); root.innerHTML=''; root.appendChild(wrap); }
    catch(e){ root.innerHTML='<pre class="schema-viewer">'+_esc(raw.textContent)+'</pre>'; }
})();
</script>
