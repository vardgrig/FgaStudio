@page
@model FgaStudio.Web.Pages.AuthModels.DetailsModel
@{
    ViewData["Title"] = "Authorization Model";
    ViewData["ActivePage"] = "Stores";
    ViewData["ActiveConnection"] = Model.ActiveConnectionName;
    ViewData["ActiveStore"] = Model.ActiveStoreId;

    var modelId = Model.ModelId ?? "";
}

<!-- Header -->
<div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-4">
    <div class="d-flex align-items-center gap-3 min-w-0">
        <a href="/Stores" class="btn btn-sm btn-outline-secondary flex-shrink-0">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div class="min-w-0">
            <h1 class="page-title mb-1 d-flex align-items-center gap-2 flex-wrap">
                Authorization Model
                @if (Model.Detail?.IsActive == true)
                {
                    <span class="badge bg-success" style="font-size:0.65rem">Active</span>
                }
            </h1>
            <div class="font-mono text-secondary small text-truncate" title="@modelId">@modelId</div>
        </div>
    </div>
    <div class="d-flex align-items-center gap-2 flex-shrink-0">
        @if (Model.Detail?.CreatedAt.HasValue == true)
        {
            <span class="badge bg-body-secondary text-body border">
                <i class="bi bi-calendar3 me-1"></i>@Model.Detail.CreatedAt!.Value.ToString("yyyy-MM-dd HH:mm")
            </span>
        }
        @if (Model.Detail?.SchemaJson is not null)
        {
            <a href="?handler=download&storeId=@Model.StoreId&modelId=@Model.ModelId"
               class="btn btn-sm btn-outline-primary">
                <i class="bi bi-download me-1"></i>Download
            </a>
        }
    </div>
</div>

@if (string.IsNullOrEmpty(Model.StoreId) || string.IsNullOrEmpty(Model.ModelId))
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>Missing storeId or modelId parameters.</div>
}
else if (Model.Error is not null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@Model.Error</div>
}
else if (Model.Detail is null)
{
    <div class="empty-state card text-center p-5">
        <i class="bi bi-diagram-3 display-4 text-secondary mb-3 d-block"></i>
        <h5>Model not found</h5>
        <p class="text-secondary mb-0">The authorization model could not be loaded.</p>
    </div>
}
else
{
    <div class="row g-4">

        <!-- ── Schema JSON ───────────────────────────────── -->
        <div class="col-lg-7">

            <!-- Toolbar -->
            <div class="d-flex align-items-center gap-2 mb-2">
                <h6 class="fw-semibold mb-0 me-auto">
                    <i class="bi bi-braces me-1 text-secondary"></i>Schema JSON
                </h6>
                @if (Model.Detail.SchemaJson is not null)
                {
                    <button class="btn btn-sm btn-outline-secondary" onclick="jvExpandAll()" title="Expand all">
                        <i class="bi bi-arrows-expand"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" onclick="jvCollapseAll()" title="Collapse all">
                        <i class="bi bi-arrows-collapse"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" id="copy-btn"
                            onclick="copySchema()" title="Copy JSON">
                        <i class="bi bi-clipboard me-1"></i>Copy
                    </button>
                    <button class="btn btn-sm btn-outline-primary"
                            onclick="downloadSchema()" title="Download as JSON file">
                        <i class="bi bi-download me-1"></i>Download
                    </button>
                }
            </div>

            @if (Model.Detail.SchemaJson is null)
            {
                <div class="card p-4">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-info-circle text-warning fs-4"></i>
                        <div>
                            <div class="fw-semibold">Schema not available</div>
                            <div class="small text-secondary">
                                Full schema retrieval requires an HTTP API connection.
                                Direct database connections cannot decode the protobuf-encoded schema.
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Hidden raw source (used by copy + download) -->
                <pre id="schema-raw" style="display:none">@Model.Detail.SchemaJson</pre>

                <!-- Interactive viewer -->
                <div class="jv-container" id="jv-root">
                    <div class="jv-loading text-secondary small p-3">
                        <i class="bi bi-hourglass-split me-1"></i>Rendering…
                    </div>
                </div>
            }
        </div>

        <!-- ── Type Definitions Tree ─────────────────────── -->
        <div class="col-lg-5">
            <h6 class="fw-semibold mb-2">
                <i class="bi bi-diagram-3 me-1 text-secondary"></i>Type Definitions
                @if (Model.Detail.TypeDefinitions.Count > 0)
                {
                    <span class="text-secondary fw-normal small ms-1">@Model.Detail.TypeDefinitions.Count type(s)</span>
                }
            </h6>

            @if (!Model.Detail.TypeDefinitions.Any())
            {
                <div class="card p-4 text-center text-secondary">
                    <i class="bi bi-diagram-3 mb-2 d-block"></i>
                    @if (Model.IsDbMode)
                    {
                        <span>Type tree requires an HTTP API connection.</span>
                    }
                    else
                    {
                        <span>No type definitions found.</span>
                    }
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-2" id="type-tree">
                    @foreach (var node in Model.Detail.TypeDefinitions)
                    {
                        var collapseId = $"type-{node.Type}";
                        <div class="type-tree-item card">
                            <button class="type-tree-item__header"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId"
                                    aria-expanded="@(node.Relations.Count > 0 ? "true" : "false")"
                                    @(node.Relations.Count == 0 ? "disabled" : "")>
                                <span class="type-tree-item__icon">
                                    <i class="bi bi-box"></i>
                                </span>
                                <span class="fw-semibold font-mono flex-grow-1 text-start">@node.Type</span>
                                @if (node.Relations.Count > 0)
                                {
                                    <span class="badge bg-body-secondary text-body border ms-auto">
                                        @node.Relations.Count relation@(node.Relations.Count != 1 ? "s" : "")
                                    </span>
                                    <i class="bi bi-chevron-down type-tree-chevron ms-1"></i>
                                }
                                else
                                {
                                    <span class="text-secondary small ms-auto">no relations</span>
                                }
                            </button>
                            @if (node.Relations.Count > 0)
                            {
                                <div class="collapse show" id="@collapseId">
                                    <ul class="type-tree-relations">
                                        @foreach (var rel in node.Relations)
                                        {
                                            <li class="type-tree-relation">
                                                <i class="bi bi-arrow-return-right text-secondary"></i>
                                                <span class="relation-badge">@rel</span>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

    </div>
}

<script>
// ─── JSON Viewer ─────────────────────────────────────────────────────────────

var _jvSeq = 0;
function _jvId() { return 'jv' + (_jvSeq++); }

function _esc(s) {
    return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
}

function _renderVal(v) {
    if (v === null)             return '<span class="jv-null">null</span>';
    if (v === true || v === false) return '<span class="jv-bool">' + v + '</span>';
    if (typeof v === 'number')  return '<span class="jv-num">' + v + '</span>';
    if (typeof v === 'string')  return '<span class="jv-str">&quot;' + _esc(v) + '&quot;</span>';
    if (Array.isArray(v))       return _renderArr(v);
    if (typeof v === 'object')  return _renderObj(v);
    return _esc(String(v));
}

function _renderObj(obj) {
    var keys = Object.keys(obj);
    if (keys.length === 0) return '<span class="jv-brace">{}</span>';
    var id = _jvId();
    var preview = keys.length + ' key' + (keys.length !== 1 ? 's' : '');
    var rows = keys.map(function(k, i) {
        var comma = i < keys.length - 1 ? '<span class="jv-punct">,</span>' : '';
        return '<div class="jv-row">'
            + '<span class="jv-key">&quot;' + _esc(k) + '&quot;</span>'
            + '<span class="jv-colon">: </span>'
            + _renderVal(obj[k])
            + comma
            + '</div>';
    }).join('');
    return '<span class="jv-brace">{</span>'
        + '<button class="jv-btn" data-jvid="' + id + '" onclick="jvToggle(this)" title="Collapse">'
        + '<i class="bi bi-dash-square-dotted"></i></button>'
        + '<span class="jv-peek" id="pk-' + id + '" style="display:none">'
        + '<span class="jv-brace">{ </span><span class="jv-dim">' + preview + '</span><span class="jv-brace"> }</span>'
        + '</span>'
        + '<div class="jv-block" id="' + id + '">' + rows + '</div>'
        + '<span class="jv-brace jv-close-brace">}</span>';
}

function _renderArr(arr) {
    if (arr.length === 0) return '<span class="jv-brace">[]</span>';
    var id = _jvId();
    var preview = arr.length + ' item' + (arr.length !== 1 ? 's' : '');
    var rows = arr.map(function(v, i) {
        var comma = i < arr.length - 1 ? '<span class="jv-punct">,</span>' : '';
        return '<div class="jv-row">' + _renderVal(v) + comma + '</div>';
    }).join('');
    return '<span class="jv-brace">[</span>'
        + '<button class="jv-btn" data-jvid="' + id + '" onclick="jvToggle(this)" title="Collapse">'
        + '<i class="bi bi-dash-square-dotted"></i></button>'
        + '<span class="jv-peek" id="pk-' + id + '" style="display:none">'
        + '<span class="jv-brace">[ </span><span class="jv-dim">' + preview + '</span><span class="jv-brace"> ]</span>'
        + '</span>'
        + '<div class="jv-block" id="' + id + '">' + rows + '</div>'
        + '<span class="jv-brace jv-close-brace">]</span>';
}

function jvToggle(btn) {
    var id    = btn.dataset.jvid;
    var block = document.getElementById(id);
    var peek  = document.getElementById('pk-' + id);
    var icon  = btn.querySelector('i');
    var open  = block.style.display !== 'none';
    block.style.display = open ? 'none' : '';
    peek.style.display  = open ? 'inline' : 'none';
    // find the closing brace sibling
    var sib = btn.parentElement.querySelector('.jv-close-brace');
    if (sib) sib.style.display = open ? 'none' : '';
    icon.className = open ? 'bi bi-plus-square-dotted' : 'bi bi-dash-square-dotted';
    btn.title = open ? 'Expand' : 'Collapse';
}

function jvExpandAll() {
    document.querySelectorAll('#jv-root .jv-btn').forEach(function(btn) {
        var id = btn.dataset.jvid;
        var block = document.getElementById(id);
        var peek  = document.getElementById('pk-' + id);
        var sib   = btn.parentElement.querySelector('.jv-close-brace');
        block.style.display = '';
        peek.style.display  = 'none';
        if (sib) sib.style.display = '';
        btn.querySelector('i').className = 'bi bi-dash-square-dotted';
        btn.title = 'Collapse';
    });
}

function jvCollapseAll() {
    // Only collapse top-level children so the root stays visible
    document.querySelectorAll('#jv-root > .jv-wrap .jv-block > .jv-row .jv-btn').forEach(function(btn) {
        var id = btn.dataset.jvid;
        var block = document.getElementById(id);
        if (!block) return;
        var peek  = document.getElementById('pk-' + id);
        var sib   = btn.parentElement.querySelector('.jv-close-brace');
        block.style.display = 'none';
        peek.style.display  = 'inline';
        if (sib) sib.style.display = 'none';
        btn.querySelector('i').className = 'bi bi-plus-square-dotted';
        btn.title = 'Expand';
    });
}

function copySchema() {
    var raw = document.getElementById('schema-raw');
    if (!raw) return;
    navigator.clipboard.writeText(raw.textContent.trim()).then(function() {
        var btn = document.getElementById('copy-btn');
        var orig = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-check me-1"></i>Copied';
        btn.classList.replace('btn-outline-secondary', 'btn-outline-success');
        setTimeout(function() {
            btn.innerHTML = orig;
            btn.classList.replace('btn-outline-success', 'btn-outline-secondary');
        }, 2000);
    });
}

function downloadSchema() {
    var raw = document.getElementById('schema-raw');
    if (!raw) return;
    var content = raw.textContent.trim();
    var modelId = '@Html.Raw(System.Text.RegularExpressions.Regex.Replace(modelId, "[^a-zA-Z0-9]", ""))';
    var filename = 'auth-model' + (modelId ? '-' + modelId.slice(0, 12) : '') + '.json';
    var blob = new Blob([content], { type: 'application/json' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
}

// ─── Boot ────────────────────────────────────────────────────────────────────
(function() {
    var raw = document.getElementById('schema-raw');
    var root = document.getElementById('jv-root');
    if (!raw || !root) return;
    try {
        var parsed = JSON.parse(raw.textContent);
        var wrap = document.createElement('div');
        wrap.className = 'jv-wrap';
        wrap.innerHTML = _renderVal(parsed);
        root.innerHTML = '';
        root.appendChild(wrap);
    } catch(e) {
        root.innerHTML = '<pre class="schema-viewer">' + _esc(raw.textContent) + '</pre>';
    }
})();

// Bootstrap collapse chevron rotation for type tree
document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(function(btn) {
    var target = document.querySelector(btn.dataset.bsTarget);
    if (!target) return;
    target.addEventListener('hide.bs.collapse', function() {
        btn.querySelector('.type-tree-chevron')?.classList.add('rotated');
    });
    target.addEventListener('show.bs.collapse', function() {
        btn.querySelector('.type-tree-chevron')?.classList.remove('rotated');
    });
});
</script>
